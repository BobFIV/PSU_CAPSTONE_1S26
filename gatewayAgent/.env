IN_CSE_BASE_URL=http://localhost:8080/~/id-in/cse-in
ORIGINATOR_ID=CgatewayAgent
CALLBACK_URL=http://host.docker.internal:9000
APPLICATION_NAME=gatewayAgent
SUBSCRIPTION_NAME=gatewaySubscription
IMAGE=ankraft/acme-onem2m-cse:latest
LOG_LEVEL=DEBUG

TLS_ENABLED=false
TLS_VERIFY=true
TLS_CA_CERT=/run/certs/ca.pem
TLS_CLIENT_CERT=/run/certs/client.crt
TLS_CLIENT_KEY=/run/certs/client.key

MAX_MN=2